{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Extension (TS Debug)",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}"
      ],
      "outFiles": ["${workspaceFolder}/dist/**/*.js"],
      "preLaunchTask": "npm: build",
      "sourceMaps": true,
      "smartStep": true
    }
  ]
}
