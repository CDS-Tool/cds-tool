{
  "name": "cds-tool",
  "displayName": "CDS Tool",
  "description": "Debug CAP on Cloud Foundry, stream logs, query HANA database — all from VS Code",
  "version": "1.0.0",
  "publisher": "cds-tool",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/CDS-Tool/cds-tool.git"
  },
  "homepage": "https://github.com/CDS-Tool/cds-tool",
  "engines": {
    "vscode": "^1.116.0",
    "node": ">=18"
  },
  "categories": [
    "Debuggers",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "bin": {
    "cds-tool": "./dist/cli.js"
  },
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "cds-tool",
          "title": "CDS Tool",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "cds-tool": [
        {
          "type": "webview",
          "id": "cdsTool.mainView",
          "name": "CDS Tool"
        }
      ]
    },
    "commands": [
      {
        "command": "cdsTool.login",
        "title": "CDS Tool: Open Panel"
      },
      {
        "command": "cdsTool.logs",
        "title": "CDS Tool: Stream App Logs (Output Channel)"
      },
      {
        "command": "cdsTool.addDbConnection",
        "title": "CDS Tool: Add Database Connection (SQLTools)"
      },
      {
        "command": "cdsTool.openApp",
        "title": "CDS Tool: Open App in Browser"
      },
      {
        "command": "cdsTool.showWatchdog",
        "title": "CDS Tool: Show App Watchdog"
      },
      {
        "command": "cdsTool.syncOrg",
        "title": "CDS Tool: Sync CF Landscape"
      },
      {
        "command": "cdsTool.getToken",
        "title": "CDS Tool: Get XSUAA Token"
      },
      {
        "command": "cdsTool.restartApp",
        "title": "CDS Tool: Restart CF App"
      },
      {
        "command": "cdsTool.brunoSetup",
        "title": "CDS Tool: Setup Bruno Collection"
      },
      {
        "command": "cdsTool.brunoRun",
        "title": "CDS Tool: Run Bruno Collection"
      },
      {
        "command": "cdsTool.gitport",
        "title": "CDS Tool: Port GitLab MR"
      },
      {
        "command": "cdsTool.jiraSearch",
        "title": "CDS Tool: Search Jira Issues"
      },
      {
        "command": "cdsTool.sharepointRead",
        "title": "CDS Tool: Read SharePoint Workbook"
      },
      {
        "command": "cdsTool.smdgLogin",
        "title": "CDS Tool: Smidge Login"
      },
      {
        "command": "cdsTool.smdgGenerate",
        "title": "CDS Tool: Generate Skill via Smidge"
      }
    ],
    "configuration": {
      "title": "CDS Tool",
      "properties": {
        "cdsTool.remoteRoot": {
          "type": "string",
          "default": "/home/vcap/app",
          "markdownDescription": "Remote root path used in debug attach config"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "node esbuild.mjs",
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "package": "vsce package --no-dependencies",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-specifier-resolution=node dist/test/unit.test.js || npx tsx src/test/unit.test.ts"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.116.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.5.0"
  }
}
